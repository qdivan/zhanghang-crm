APP_NAME=账航·一帆财税 API
ENVIRONMENT=dev
DATABASE_URL=sqlite+pysqlite:///./daizhang.db
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
CORS_ALLOW_ORIGINS=*
BOOTSTRAP_DEMO_DATA=true
BOOTSTRAP_DEMO_PASSWORD=Daizhang#2026!
RESET_DB_ON_STARTUP=true

# SSO / OIDC（Keycloak）
SSO_ENABLED=false
SSO_PROVIDER_LABEL=企业单点登录
