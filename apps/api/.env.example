OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_SCOPES=openid profile email
APP_PUBLIC_BASE_URL=http://127.0.0.1:5173
OIDC_POST_LOGOUT_REDIRECT_URL=

# 迁移期建议保留 true；全部绑定完成后可按需改为 false
LOCAL_LOGIN_ENABLED=true
